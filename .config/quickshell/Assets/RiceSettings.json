{
  "system": {
    "keyboard_layout": "latam",
    "timezone": "America/Mexico_City",
    "clock_24h": true
  },
  "connections": {
    "network": {
      "network": {
        "enabled": true,
        "wifi": "",
        "ethernet": "",
        "airplane_mode": false
      },
      "access_point": {
        "enabled": false,
